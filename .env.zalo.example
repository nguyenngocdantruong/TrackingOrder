### Zalo Bot configuration (python-zalo-bot)
# Bot token from Zalo Official Account / Bot settings
ZALO_BOT_TOKEN=replace-with-your-zalo-bot-token

# Public base URL of the web app (used to build link callback)
WEBSITE_URL=http://127.0.0.1:5000

# Optional: switch to webhook mode (set URL and secret). Leave empty to use polling.
ZALO_BOT_WEBHOOK_URL=
ZALO_BOT_SECRET_TOKEN=
