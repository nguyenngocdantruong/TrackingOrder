SECRET_KEY=yoursecretkeyhere
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON_PATH=service-account.json
TELEGRAM_BOT_TOKEN=your_bot_token_here
MAX_EVENTS_PER_TRACKING=50
SCHEDULER_ENABLED=true
POLL_INTERVAL_SECONDS=300
WEBSITE_URL=http://127.0.0.1:5000
ADMIN_TELEGRAM_USER_ID=123456789

LOG_FILE=logs/app.log
LOG_LEVEL=INFO/WARNING/ERROR/DEBUG

PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://abc.com/payments/return
PAYOS_CANCEL_URL=http://abc.com/payments/cancel
DONATE_NOTIFY_ALL=0

### Zalo Bot configuration (python-zalo-bot)
# Bot token from Zalo Official Account / Bot settings
ZALO_BOT_TOKEN=your_zalo_bot_token

# Public base URL of the web app (used to build link callback)
WEBSITE_URL=https://app.dev8084.io.vn/

# Power Outage
POWER_OUTAGE_ENABLED=true
POWER_OUTAGE_INTERVAL_SECONDS=21600